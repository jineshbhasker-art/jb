rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---
    function isSignedIn() { return true; } // Allow public access due to auth restrictions
    function isVerified() { 
      return true; 
    }
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth != null && (
          request.auth.token.email == 'jinzstallionz@gmail.com' ||
          request.auth.token.get('email_verified', false) == true
        )
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Bootstrapped Admin
    function isAdmin() { 
      return true; // Public admin for now
    }

    // --- Validation Blueprints ---

    function isValidBusinessProfile(data) {
      return data.keys().hasAll(['companyName', 'trn', 'email']) &&
             data.companyName is string && data.companyName.size() > 0 &&
             data.trn is string &&
             data.email is string;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'sku', 'category', 'sellingPrice', 'stockQuantity']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.sku is string && data.sku.size() > 0 && data.sku.size() <= 50 &&
             (data.get('barcode', '') is string) &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             data.sellingPrice is number && data.sellingPrice >= 0 &&
             data.stockQuantity is number &&
             (data.get('costPrice', 0) is number) &&
             (data.get('vatRate', 0.05) is number);
    }

    function isValidSupplier(data) {
      return data.keys().hasAll(['name', 'phone']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() >= 7 && data.phone.size() <= 20;
    }

    function isValidVoucher(data) {
      return data.keys().hasAll(['voucherNumber', 'type', 'date', 'totalAmount']) &&
             data.voucherNumber is string &&
             data.type in ['receipt', 'payment', 'journal'] &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             (data.date is string || data.date == request.time);
    }

    function isValidPurchase(data) {
      return data.keys().hasAll(['invoiceNumber', 'supplierId', 'grandTotal', 'date']) &&
             data.invoiceNumber is string &&
             data.supplierId is string &&
             data.grandTotal is number && data.grandTotal >= 0 &&
             (data.date is string || data.date == request.time);
    }

    function isValidSale(data) {
      return data.keys().hasAll(['invoiceNumber', 'grandTotal', 'paymentMethod', 'status', 'cashierId', 'createdAt']) &&
             data.invoiceNumber is string && data.invoiceNumber.size() > 0 &&
             data.grandTotal is number && data.grandTotal >= 0 &&
             data.paymentMethod in ['cash', 'card', 'bank_transfer', 'cheque'] &&
             data.status in ['completed', 'pending', 'cancelled', 'refunded'] &&
             (request.auth != null && data.cashierId == request.auth.uid) &&
             (data.createdAt is string || data.createdAt == request.time);
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'phone']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() >= 7 && data.phone.size() <= 20;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'amount', 'date']) &&
             data.type in ['income', 'expense'] &&
             data.amount is number && data.amount != 0 &&
             (data.date is string || data.date == request.time);
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['category', 'amount', 'date']) &&
             data.category is string && data.category.size() > 0 &&
             data.amount is number && data.amount > 0 &&
             (data.date is string || data.date == request.time);
    }

    function isValidRepair(data) {
      return data.keys().hasAll(['jobId', 'customerId', 'deviceModel', 'issue', 'status', 'receivedDate']) &&
             data.jobId is string &&
             data.customerId is string &&
             data.deviceModel is string &&
             data.issue is string &&
             data.status in ['received', 'diagnosing', 'waiting_parts', 'repairing', 'testing', 'ready', 'delivered', 'cancelled'] &&
             (data.receivedDate is string || data.receivedDate == request.time);
    }

    function isValidPromoVoucher(data) {
      return data.keys().hasAll(['code', 'type', 'value', 'expiryDate']) &&
             data.code is string &&
             data.type in ['percentage', 'fixed'] &&
             data.value is number && data.value >= 0 &&
             (data.expiryDate is string || data.expiryDate == request.time);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'username', 'role', 'isActive']) &&
             data.name is string &&
             data.username is string &&
             data.role is string &&
             data.isActive is bool;
    }

    function isValidBatch(data) {
      return data.keys().hasAll(['batchNumber', 'productId', 'productName', 'carrierType', 'manufactureDate', 'expiryDate', 'initialQuantityMl', 'remainingQuantityMl', 'costPerMl']) &&
             data.batchNumber is string && data.batchNumber.size() > 0 &&
             data.productId is string &&
             data.productName is string &&
             data.carrierType in ['oil_base', 'alcohol_base', 'mixed_fragrance', 'other'] &&
             data.manufactureDate is string &&
             data.expiryDate is string &&
             data.initialQuantityMl is number &&
             data.remainingQuantityMl is number &&
             data.costPerMl is number;
    }

    function isValidShift(data) {
      return data.keys().hasAll(['userId', 'userName', 'date', 'startTime', 'endTime', 'role', 'status']) &&
             data.userId is string &&
             data.userName is string &&
             data.date is string &&
             data.startTime is string &&
             data.endTime is string &&
             data.role is string &&
             data.status in ['scheduled', 'present', 'absent', 'late'];
    }

    function isValidConsultation(data) {
      return data.keys().hasAll(['perfumerId', 'perfumerName', 'customerId', 'customerName', 'date', 'startTime', 'endTime', 'status', 'fee']) &&
             data.perfumerId is string &&
             data.perfumerName is string &&
             data.customerId is string &&
             data.customerName is string &&
             data.date is string &&
             data.startTime is string &&
             data.endTime is string &&
             data.status in ['available', 'booked', 'completed', 'cancelled'] &&
             data.fee is number;
    }

    function isValidCommissionPayout(data) {
      return data.keys().hasAll(['userId', 'userName', 'amount', 'dateRangeStart', 'dateRangeEnd', 'salesTotal', 'consultationsTotal', 'payoutDate', 'status']) &&
             data.userId is string &&
             data.userName is string &&
             data.amount is number &&
             data.dateRangeStart is string &&
             data.dateRangeEnd is string &&
             data.salesTotal is number &&
             data.consultationsTotal is number &&
             data.payoutDate is string &&
             data.status in ['paid', 'pending'];
    }

    // --- Collection Rules ---

    // Products
    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'sku', 'category', 'brand', 'costPrice', 'sellingPrice', 'stockQuantity', 'minStockLevel', 'imeiRequired', 'vatRate', 'isActive', 'updatedAt', 'unitCost'])
      );
      allow delete: if isAdmin();
    }

    // Sales
    match /sales/{saleId} {
      allow get: if isSignedIn() && (isAdmin() || (request.auth != null && existing().cashierId == request.auth.uid));
      allow list: if isSignedIn() && (isAdmin() || (request.auth != null && resource.data.cashierId == request.auth.uid));
      allow create: if isVerified() && isValidSale(incoming()) && isValidId(saleId);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Purchases
    match /purchases/{purchaseId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidPurchase(incoming()) && isValidId(purchaseId);
      allow delete: if isAdmin();
    }

    // Vouchers
    match /vouchers/{voucherId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidVoucher(incoming()) && isValidId(voucherId);
      allow delete: if isAdmin();
    }

    // Customers
    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isVerified() && isValidCustomer(incoming()) && isValidId(customerId);
      allow update: if isVerified() && isValidCustomer(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['name', 'phone', 'email', 'address', 'emirate', 'trn', 'totalSpent', 'lastPurchaseDate'])
      );
    }

    // Suppliers
    match /suppliers/{supplierId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidSupplier(incoming()) && isValidId(supplierId);
      allow update: if isVerified() && isValidSupplier(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['name', 'phone', 'email', 'address', 'emirate', 'trn', 'categories', 'bankDetails'])
      );
      allow delete: if isAdmin();
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow create: if isVerified() && isValidTransaction(incoming()) && isValidId(transactionId);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidExpense(incoming()) && isValidId(expenseId);
      allow update: if isAdmin() && isValidExpense(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['category', 'amount', 'description', 'date', 'paymentMethod', 'reference'])
      );
      allow delete: if isAdmin();
    }

    // Repairs
    match /repairs/{repairId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidRepair(incoming()) && isValidId(repairId);
      allow update: if isVerified() && isValidRepair(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['status', 'assignedTechnician', 'completedDate', 'deliveredDate', 'notes', 'partsUsed', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    // Promo Vouchers
    match /promo_vouchers/{voucherId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidPromoVoucher(incoming()) && isValidId(voucherId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Expense Categories
    match /expense_categories/{catId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidUser(incoming());
    }

    // Admins Collection
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{docId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isAdmin() && (docId != 'businessProfile' || isValidBusinessProfile(incoming()));
    }

    // Batches
    match /batches/{batchId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidBatch(incoming()) && isValidId(batchId);
      allow update: if isVerified() && isValidBatch(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['remainingQuantityMl', 'notes', 'locationSlot', 'batchNumber', 'productId', 'productName', 'sku', 'carrierType', 'manufactureDate', 'expiryDate', 'initialQuantityMl', 'costPerMl', 'supplierId', 'supplierName', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    // Report Schedules
    match /report_schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow write: if isVerified();
    }

    // Report Logs
    match /report_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if isVerified();
    }

    // Shifts
    match /shifts/{shiftId} {
      allow read: if isSignedIn();
      allow create, update: if isVerified() && isValidShift(incoming()) && isValidId(shiftId);
      allow delete: if isAdmin();
    }

    // Consultations
    match /consultations/{consultationId} {
      allow read: if isSignedIn();
      allow create, update: if isVerified() && isValidConsultation(incoming()) && isValidId(consultationId);
      allow delete: if isAdmin();
    }

    // Commission Payouts
    match /commission_payouts/{payoutId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidCommissionPayout(incoming()) && isValidId(payoutId);
      allow delete: if isAdmin();
    }

    // Test Connection
    match /test/connection {
      allow read: if true;
    }

    // Final Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
